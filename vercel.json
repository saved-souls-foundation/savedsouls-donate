{
  "crons": [
    {
      "path": "/api/admin/sponsors/check-expiry",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/newsletter",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/ai/test-spotlight",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/scrape-gofundme",
      "schedule": "0 20 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.savedsouls-foundation.com"
        }
      ],
      "destination": "https://www.savedsouls-foundation.org/:path*",
      "permanent": true
    }
  ]
}
